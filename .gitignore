# ==============================================================================
# AI Productivity Agent v3.0 — .gitignore
# ==============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Virtual environments
venv/
.venv/
env/
.env/

# Distribution / packaging
*.egg-info/
dist/
build/
*.egg
cred
cred/
# Environment secrets — NEVER commit
.env

# Database files
*.db
*.db-shm
*.db-wal

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log

# pytest
.pytest_cache/
.coverage
htmlcov/

# mypy
.mypy_cache/
