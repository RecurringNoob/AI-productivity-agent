# ==============================================================================
# AI Productivity Agent v3.0 — Environment Variables Reference
# Copy this file to .env and fill in values. Never commit .env to git.
# Source of truth: Design Document v3.0, Section 11 (Migration Guide)
# ==============================================================================

# ------------------------------------------------------------------------------
# Required — LLM
# ------------------------------------------------------------------------------
GOOGLE_API_KEY=your_google_api_key_here

# ------------------------------------------------------------------------------
# Optional — Database
# Defaults to local SQLite file. Override for a different path.
# ------------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./agent_memory.db

# ------------------------------------------------------------------------------
# Optional — Gmail integration (swap StubEmailAdapter for GmailEmailAdapter)
# ------------------------------------------------------------------------------
GMAIL_CREDENTIALS_PATH=

# ------------------------------------------------------------------------------
# Optional — LangSmith observability tracing
# ------------------------------------------------------------------------------
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true

# ------------------------------------------------------------------------------
# Optional — Hardening defaults
# ------------------------------------------------------------------------------
# Time window before a pending HITL action is auto-expired (minutes)
HITL_EXPIRY_MINUTES=30

# Travel buffer added to both sides of overlap queries (minutes)
CALENDAR_TRAVEL_BUFFER_MINUTES=15

# ------------------------------------------------------------------------------
# Optional — Timezone
# IANA timezone string used as fallback when user_timezone is not in request
# ------------------------------------------------------------------------------
DEFAULT_USER_TIMEZONE=IST
